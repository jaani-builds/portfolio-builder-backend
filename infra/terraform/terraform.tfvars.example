aws_region           = "us-east-1"
project_name         = "portfolio-builder"
environment          = "dev"
frontend_url         = "https://your-frontend.example.com"
github_client_id     = "replace-me"
github_client_secret = "replace-me"
jwt_secret           = "replace-with-a-long-random-secret"
alert_email          = "you@example.com"
monthly_budget_limit_usd      = 10
budget_alert_threshold_percent = 80
create_billing_alarm           = true

# Build a deployment zip and point this path to it.
lambda_zip_path = "../../dist/lambda.zip"

# Optional. Set if you serve objects via CloudFront/custom domain.
aws_public_base_url = ""

# Optional backend custom domain (API Gateway).
# api_custom_domain        = "api.yourdomain.com"
# api_acm_certificate_arn  = "arn:aws:acm:us-east-1:123456789012:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
