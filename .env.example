# Environment variables for portfolio-builder backend

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5174

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── LinkedIn OAuth ────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── AWS storage and metadata ─────────────────────────────────────────────────-
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_DDB_TABLE=
AWS_S3_PREFIX=portfolio-builder
# Optional CloudFront/custom domain base URL for public object access
AWS_PUBLIC_BASE_URL=

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-me-with-a-long-random-string

# Local-only workaround for environments with intercepted TLS certificate chains.
# Keep false in normal setups and all production deployments.
AWS_INSECURE_SSL=false

# ── Portfolio template ────────────────────────────────────────────────────────
# Path to the jaani-builds.github.io repo (or any copy of the template).
# The backend reads index.html and the assets/ directory from this path.
PORTFOLIO_TEMPLATE_DIR=../jaani-builds.github.io

